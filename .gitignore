# ============================================
# 根目录 .gitignore（兜底）
# 子目录的 .gitignore 仍生效
# ============================================

# 敏感：环境变量
.env
.env.*
!.env.example

# 运行时数据
data/
*.db
*.sqlite
*.sqlite3

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# Node
node_modules/
dist/
dist-ssr/
*.local

# IDE / 编辑器
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store

# 日志
*.log
logs/

# Cursor
.cursor/plans/*.local.md
.cursor/cache/

# 临时
*.tmp
*.bak
*.swp

# 本地工具二进制
# scripts/bin/gitleaks.exe 由开发者本地放置，**不** commit（体积大）
scripts/bin/
!scripts/seed_db.py
