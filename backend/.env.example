# ============================================
# .env.example — 复制为 .env 后填入真实值
# ============================================

# 应用配置
APP_NAME=智能数据分析助理
APP_VERSION=0.3.0
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# 阿里云百炼 Qwen3 配置
# 在 https://dashscope.console.aliyun.com/apiKey 申请
# ⚠️ 重要：真实 key 必须放在 .env（本文件已被 .gitignore 排除），本文件 (.env.example) 只能用占位符
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-max

# CORS 配置（JSON 数组格式，按需添加 dev 端口）
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:5175","http://localhost:3000"]
